# ==============================================
# 1. 模型权重、检查点（核心大文件，必须屏蔽）
# ==============================================
ckpt/
model/
*.pt
*.pth
*.bin
*.ckpt

# ==============================================
# 2. 数据集、实验统计结果（你截图里的npz等大文件）
# ==============================================
stats/
dataset/
*.npy
*.npz
*.csv
*.h5
*.hdf5

# ==============================================
# 3. PyCharm IDE 配置文件（完全不需要上传）
# ==============================================
.idea/
*.iml
*.iws
*.ipr
.idea/modules.xml
.idea/vcs.xml
.idea/.gitignore

# ==============================================
# 4. Python 缓存、虚拟环境、临时文件
# ==============================================
**/__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
venv/
env/
ENV/
env.bak/
venv.bak/

# ==============================================
# 5. 日志、临时文件、系统文件
# ==============================================
logs/
*.log
*.tmp
*.temp
.DS_Store
Thumbs.db